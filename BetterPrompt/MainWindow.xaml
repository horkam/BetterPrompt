<Window x:Class="BetterPrompt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BetterPrompt.ViewModels"
        xmlns:conv="clr-namespace:BetterPrompt.Converters"
        mc:Ignorable="d"
        Title="BetterPrompt" Height="780" Width="1100"
        Icon="Assets/app.ico"
        Background="{DynamicResource BgDeep}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

        <!-- Theme toggle RadioButton style — defined here so it uses DynamicResource brushes -->
        <Style x:Key="ThemeToggle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Better" FontFamily="Segoe UI Semibold" FontSize="20"
                               Foreground="{DynamicResource Accent}"/>
                    <TextBlock Text="Prompt" FontFamily="Segoe UI Semibold" FontSize="20"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="  /  Claude Code prompt optimizer"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Theme toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Content="Dark"   Style="{StaticResource ThemeToggle}" GroupName="Theme"
                                 IsChecked="{Binding IsThemeDark,   Mode=TwoWay}" Margin="0,0,2,0"/>
                    <RadioButton Content="Light"  Style="{StaticResource ThemeToggle}" GroupName="Theme"
                                 IsChecked="{Binding IsThemeLight,  Mode=TwoWay}" Margin="0,0,2,0"/>
                    <RadioButton Content="System" Style="{StaticResource ThemeToggle}" GroupName="Theme"
                                 IsChecked="{Binding IsThemeSystem, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <TabControl Grid.Row="1" Background="{DynamicResource BgDeep}">

            <!-- NEW PROJECT TAB -->
            <TabItem Header="New Project">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Scoping form -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24" MaxWidth="600">

                            <!-- Header + Load button -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="NEW PROJECT SCOPE" FontFamily="Segoe UI Semibold" FontSize="10"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Fill in the form and generate a CLAUDE.md that gives Claude Code full context from day one. Use the AI assistant on the right if you need help thinking through any section."
                                               FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Load Existing Project"
                                        Style="{DynamicResource SecondaryButton}"
                                        Command="{Binding NewProject.LoadProjectCommand}"
                                        Padding="12,6" VerticalAlignment="Top" Margin="12,0,0,0"/>
                            </Grid>

                            <!-- IDENTITY -->
                            <TextBlock Text="IDENTITY" FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Project Name" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about project naming"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="ProjectName"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="One-line description" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about your project description"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="Description"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.Description, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Primary goal — what problem does this solve?" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about your project goal"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="Goal"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.Goal, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" Height="72"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>

                            <!-- AUDIENCE -->
                            <TextBlock Text="AUDIENCE" FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Who are the target users?" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about your target audience"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="TargetAudience"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.TargetAudience, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Border>

                            <!-- TECHNICAL STACK -->
                            <TextBlock Text="TECHNICAL STACK" FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Platform" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about platform considerations"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="Platform"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <ComboBox ItemsSource="{Binding NewProject.PlatformOptions}"
                                              SelectedItem="{Binding NewProject.Platform}"
                                              Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Primary language / framework  (e.g. C# / WPF, TypeScript / React)" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about language and framework choices"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="Language"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.Language, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Database / storage  (e.g. SQLite, PostgreSQL, None)" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about database and storage options"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="Database"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.Database, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Border>

                            <!-- FEATURES -->
                            <TextBlock Text="FEATURES" FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Core features  (one per line)" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI to help define your core features"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="CoreFeatures"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.CoreFeatures, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Explicitly out of scope  (one per line)" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about what to exclude from scope"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="OutOfScope"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.OutOfScope, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" Height="72"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>

                            <!-- CONSTRAINTS -->
                            <TextBlock Text="CONSTRAINTS" FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Non-functional requirements  (performance, security, offline support, etc.)" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about non-functional requirements"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="NonFunctionalRequirements"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.NonFunctionalRequirements, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" Height="72"
                                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Estimated timeline  (e.g. 2 weeks, 3 months)" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about setting a realistic timeline"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="Timeline"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.Timeline, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Similar apps / reference  (for inspiration or comparison)" Padding="0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="?" ToolTip="Ask AI about similar apps and reference projects"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.AskAboutFieldCommand}"
                                                CommandParameter="SimilarApps"
                                                Padding="6,2" FontSize="10"/>
                                    </Grid>
                                    <TextBox Text="{Binding NewProject.SimilarApps, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Border>

                            <!-- OUTPUT -->
                            <TextBlock Text="OUTPUT" FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,16">
                                <StackPanel>
                                    <Label Content="Project directory  (will be created if it doesn't exist)" Padding="0,0,0,4"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding NewProject.ProjectPath, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="..." Margin="6,0,0,0" Padding="10,6"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.BrowseProjectPathCommand}"/>
                                    </Grid>
                                    <Button Content="Generate Project Files"
                                            Command="{Binding NewProject.GenerateProjectCommand}"
                                            HorizontalAlignment="Left" Padding="16,9" FontSize="13"/>
                                    <Grid Margin="0,12,0,0"
                                          Visibility="{Binding NewProject.HasGenerateStatus, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding NewProject.GenerateStatus}"
                                                   FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFCC4444"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NewProject.GenerateSuccess}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Grid.Column="1" Content="Open Folder"
                                                Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding NewProject.OpenProjectFolderCommand}"
                                                Visibility="{Binding NewProject.GenerateSuccess, Converter={StaticResource BoolToVis}}"
                                                Padding="10,4" Margin="10,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- RIGHT: AI assistant chat -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource Border}" BorderThickness="1,0,0,0"
                            Background="{DynamicResource BgPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Chat header -->
                            <Border Grid.Row="0" Padding="14,12"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="AI ASSISTANT" FontFamily="Segoe UI Semibold" FontSize="10"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,3"/>
                                    <TextBlock Text="Ask anything — goals, features, tech choices, trade-offs."
                                               FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                                    <TextBlock Text="Powered by your configured AI provider — see Settings."
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Messages -->
                            <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="10,8">
                                <ItemsControl ItemsSource="{Binding NewProject.ChatHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" CornerRadius="4" Padding="10,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BgCard}"/>
                                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="user">
                                                                <Setter Property="Background" Value="{DynamicResource Accent}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Role}" Value="error">
                                                                <Setter Property="Background" Value="#33CC4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Content}"
                                                               FontFamily="Segoe UI" FontSize="12"
                                                               TextWrapping="Wrap" Margin="0,0,0,6">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Role}" Value="user">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Role}" Value="error">
                                                                        <Setter Property="Foreground" Value="#FFCC4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Copy button on assistant messages only -->
                                                    <Button Content="Copy"
                                                            Style="{DynamicResource SecondaryButton}"
                                                            Command="{Binding DataContext.NewProject.CopyChatMessageCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Content}"
                                                            Visibility="{Binding IsAssistant, Converter={StaticResource BoolToVis}}"
                                                            HorizontalAlignment="Left"
                                                            Padding="8,3" FontSize="10"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Chat input -->
                            <Border Grid.Row="2" Padding="10"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding NewProject.ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 MaxHeight="80" VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Segoe UI" FontSize="12"
                                                 IsEnabled="{Binding NewProject.IsChatting, Converter={StaticResource InvBoolToVis}}"
                                                 PreviewKeyDown="ChatInputBox_KeyDown"
                                                 x:Name="ChatInputBox"/>
                                        <Button Grid.Column="1" Content="Send"
                                                Command="{Binding NewProject.SendChatMessageCommand}"
                                                Padding="12,6" Margin="6,0,0,0" VerticalAlignment="Bottom"
                                                IsEnabled="{Binding NewProject.IsChatting, Converter={StaticResource InvBoolToVis}}"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Margin="0,6,0,0"
                                               Text="Thinking..."
                                               FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{DynamicResource Accent}"
                                               Visibility="{Binding NewProject.IsChatting, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>

                        </Grid>
                    </Border>

                </Grid>
            </TabItem>

            <!-- PROMPT ORGANIZER TAB -->
            <TabItem Header="Prompt Organizer">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Codebase panel -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="CODEBASE"
                                   FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,10"/>

                        <!-- Path row -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding CodebasePath, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="..." Margin="6,0,0,0" Padding="10,6"
                                    Style="{DynamicResource SecondaryButton}"
                                    Command="{Binding BrowseCodebaseCommand}"/>
                        </Grid>

                        <Button Grid.Row="2" Content="Index Codebase"
                                Command="{Binding IndexCodebaseCommand}"
                                IsEnabled="{Binding IsIndexing, Converter={StaticResource InvBoolToVis}}"
                                Margin="0,0,0,12" HorizontalAlignment="Stretch"/>

                        <!-- File tree -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="FILES" FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding FileTree}"
                                     Visibility="{Binding HasCodebase, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Grid.Row="1" Text="No codebase loaded"
                                       Foreground="{DynamicResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding HasCodebase, Converter={StaticResource InvBoolToVis}}"/>
                        </Grid>
                    </Grid>

                    <!-- Right: Prompt panel -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Raw prompt -->
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="YOUR PROMPT"
                                       FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <Grid Grid.Row="1">
                                <TextBox Text="{Binding RawPrompt, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Segoe UI" FontSize="13"
                                         IsEnabled="{Binding HasCodebase}"/>
                                <!-- Overlay shown when no codebase is loaded -->
                                <Border Background="{DynamicResource BgOverlay}" CornerRadius="4"
                                        Visibility="{Binding HasCodebase, Converter={StaticResource InvBoolToVis}}"
                                        IsHitTestVisible="False">
                                    <TextBlock Text="Index a codebase to enable prompt optimization"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontFamily="Segoe UI" FontSize="13" FontStyle="Italic"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Optimize button row -->
                        <Grid Grid.Row="1" Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Height="1" Background="{DynamicResource Border}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Optimize Prompt"
                                    Padding="20,10" FontSize="14"
                                    Command="{Binding OptimizePromptCommand}"
                                    IsEnabled="{Binding CanOptimize}"/>
                            <Border Grid.Column="2" Height="1" Background="{DynamicResource Border}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Stats strip -->
                        <Border Grid.Row="2" Margin="0,0,0,10"
                                Visibility="{Binding HasOptimizedPrompt, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Rules applied -->
                                <Border Grid.Column="0" Background="{DynamicResource BgCard}"
                                        CornerRadius="4" Padding="10,8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="RULES APPLIED" FontFamily="Segoe UI Semibold" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding StatRulesApplied}" FontFamily="Segoe UI Semibold"
                                                   FontSize="22" Foreground="{DynamicResource Accent}"/>
                                    </StackPanel>
                                </Border>

                                <!-- LLM used -->
                                <Border Grid.Column="1" CornerRadius="4" Padding="10,8" Margin="0,0,6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatOllamaUsed}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BgGreenTint}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="OLLAMA PASS" FontFamily="Segoe UI Semibold" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock FontFamily="Segoe UI Semibold" FontSize="22">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="No"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatOllamaUsed}" Value="True">
                                                            <Setter Property="Text" Value="Yes"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Cache hit -->
                                <Border Grid.Column="2" CornerRadius="4" Padding="10,8" Margin="0,0,6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatCacheHit}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BgGreenTint}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="CACHE HIT" FontFamily="Segoe UI Semibold" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock FontFamily="Segoe UI Semibold" FontSize="22">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="No"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatCacheHit}" Value="True">
                                                            <Setter Property="Text" Value="Yes"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   Visibility="{Binding StatCacheHit, Converter={StaticResource BoolToVis}}">
                                            <TextBlock.Text>
                                                <Binding Path="StatCacheScore" StringFormat="{}{0:P0} match"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Chars delta -->
                                <Border Grid.Column="3" Background="{DynamicResource BgCard}"
                                        CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="CHARS DELTA" FontFamily="Segoe UI Semibold" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding StatOriginalLength}" FontFamily="Segoe UI Semibold"
                                                       FontSize="14" Foreground="{DynamicResource TextSecondary}"
                                                       VerticalAlignment="Bottom"/>
                                            <TextBlock Text=" → " FontFamily="Segoe UI" FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}" VerticalAlignment="Bottom"/>
                                            <TextBlock Text="{Binding StatOptimizedLength}" FontFamily="Segoe UI Semibold"
                                                       FontSize="14" Foreground="{DynamicResource Accent}"
                                                       VerticalAlignment="Bottom"/>
                                        </StackPanel>
                                        <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="10">
                                            <TextBlock.Text>
                                                <Binding Path="StatCharsRemoved" StringFormat="{}{0} chars trimmed"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Optimized prompt -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Header row with source badge -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="OPTIMIZED PROMPT"
                                           FontFamily="Segoe UI Semibold" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                <!-- Source badge -->
                                <Border Grid.Column="1" Margin="8,0,0,0" Padding="6,2"
                                        CornerRadius="3"
                                        Visibility="{Binding HasOptimizedPrompt, Converter={StaticResource BoolToVis}}">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FromCache}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BgGreenTint}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SourceLabel}"
                                               FontFamily="Segoe UI" FontSize="10" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FromCache}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <!-- Remove cache entry button — only shown on cache hits -->
                                <Button Grid.Column="2" Content="Remove Entry"
                                        Style="{DynamicResource SecondaryButton}"
                                        Command="{Binding RemoveCachedEntryCommand}"
                                        Visibility="{Binding FromCache, Converter={StaticResource BoolToVis}}"
                                        HorizontalAlignment="Left" Margin="8,0,0,0" Padding="8,2" FontSize="10"/>
                            </Grid>
                            <TextBox Grid.Row="1"
                                     Text="{Binding OptimizedPrompt, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Segoe UI" FontSize="13"
                                     IsReadOnly="False"/>
                        </Grid>

                        <!-- Changes + copy -->
                        <Grid Grid.Row="4" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Explanation + changes -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0"
                                        Visibility="{Binding HasOptimizedPrompt, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Explanation}"
                                           Foreground="{DynamicResource Green}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding Changes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat='- {0}'}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontFamily="Segoe UI" FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <Button Content="Copy Prompt"
                                        Style="{DynamicResource SecondaryButton}"
                                        Command="{Binding CopyToClipboardCommand}"
                                        IsEnabled="{Binding HasOptimizedPrompt}"
                                        Padding="14,8"/>
                                <Button Content="Copy Rules"
                                        Style="{DynamicResource SecondaryButton}"
                                        Command="{Binding CopyRulesCommand}"
                                        IsEnabled="{Binding HasOptimizedPrompt}"
                                        Padding="14,8" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- LEARNING CACHE TAB -->
            <TabItem Header="Learning Cache">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="LEARNING CACHE" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                        <TextBlock FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondary}">
                            <Run Text="Stored optimizations for the current codebase. Entries are reused when a new prompt is "/>
                            <Run Text="{Binding Settings.SimilarityThreshold, StringFormat={}{0:P0}}"/>
                            <Run Text=" or more similar to the original."/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Toolbar -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Foreground="{DynamicResource Accent}" FontFamily="Segoe UI Semibold" FontSize="13"
                                       Text="{Binding LearningEntryCount}" VerticalAlignment="Center"/>
                            <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="12"
                                       Text=" entries" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Clear All"
                                Style="{DynamicResource SecondaryButton}"
                                Command="{Binding ClearAllCacheCommand}"
                                IsEnabled="{Binding LearningEntryCount}"
                                Padding="12,6"/>
                    </Grid>

                    <!-- Entry list -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CacheEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                                                Padding="12,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding OriginalPrompt}"
                                                               FontFamily="Segoe UI" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               TextWrapping="Wrap" MaxHeight="40"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding Source}"
                                                                   FontFamily="Segoe UI" FontSize="10"
                                                                   Foreground="{DynamicResource Accent}"
                                                                   Margin="0,0,10,0"/>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                                   FontFamily="Segoe UI" FontSize="10"
                                                                   Foreground="{DynamicResource TextMuted}"/>
                                                        <TextBlock Text=" · "
                                                                   FontFamily="Segoe UI" FontSize="10"
                                                                   Foreground="{DynamicResource TextMuted}"/>
                                                        <TextBlock Text="{Binding Machine}"
                                                                   FontFamily="Segoe UI" FontSize="10"
                                                                   Foreground="{DynamicResource TextMuted}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Delete"
                                                        Style="{DynamicResource SecondaryButton}"
                                                        Command="{Binding DataContext.DeleteCacheEntryCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Id}"
                                                        VerticalAlignment="Center" Padding="8,4" FontSize="11"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </TabItem>

            <!-- SETTINGS TAB -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24" MaxWidth="540">
                        <TextBlock Text="SETTINGS" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"/>

                        <!-- AI Provider selector -->
                        <TextBlock Text="AI PROVIDER" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Select which AI the New Project assistant uses."
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <RadioButton Content="Ollama (local)" Margin="0,0,16,0"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 IsChecked="{Binding ProviderIsOllama, Mode=TwoWay}"/>
                                    <RadioButton Content="Claude" Margin="0,0,16,0"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 IsChecked="{Binding ProviderIsClaude, Mode=TwoWay}"/>
                                    <RadioButton Content="OpenAI" Margin="0,0,16,0"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 IsChecked="{Binding ProviderIsOpenAI, Mode=TwoWay}"/>
                                    <RadioButton Content="Gemini"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 IsChecked="{Binding ProviderIsGemini, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Claude section -->
                        <TextBlock Text="CLAUDE (Anthropic)" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"
                                   Visibility="{Binding ProviderIsClaude, Converter={StaticResource BoolToVis}}"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                                Visibility="{Binding ProviderIsClaude, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ClaudeStatus}"
                                               VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFCC4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ClaudeAvailable}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="Test" Padding="10,4"
                                            Style="{DynamicResource SecondaryButton}"
                                            Command="{Binding TestClaudeCommand}"/>
                                </Grid>
                                <Label Content="API Key" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.AnthropicApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>
                                <Label Content="Model" Padding="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding ClaudeModels, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneTime}"
                                          SelectedItem="{Binding Settings.ClaudeModel}"/>
                            </StackPanel>
                        </Border>

                        <!-- OpenAI section -->
                        <TextBlock Text="OPENAI" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"
                                   Visibility="{Binding ProviderIsOpenAI, Converter={StaticResource BoolToVis}}"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                                Visibility="{Binding ProviderIsOpenAI, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding OpenAiStatus}"
                                               VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFCC4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OpenAiAvailable}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="Test" Padding="10,4"
                                            Style="{DynamicResource SecondaryButton}"
                                            Command="{Binding TestOpenAiCommand}"/>
                                </Grid>
                                <Label Content="API Key" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>
                                <Label Content="Model" Padding="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding OpenAiModels, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneTime}"
                                          SelectedItem="{Binding Settings.OpenAiModel}"/>
                            </StackPanel>
                        </Border>

                        <!-- Gemini section -->
                        <TextBlock Text="GOOGLE GEMINI" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"
                                   Visibility="{Binding ProviderIsGemini, Converter={StaticResource BoolToVis}}"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                                Visibility="{Binding ProviderIsGemini, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding GeminiStatus}"
                                               VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFCC4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GeminiAvailable}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="Test" Padding="10,4"
                                            Style="{DynamicResource SecondaryButton}"
                                            Command="{Binding TestGeminiCommand}"/>
                                </Grid>
                                <Label Content="API Key" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.GeminiApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>
                                <Label Content="Model" Padding="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding GeminiModels, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneTime}"
                                          SelectedItem="{Binding Settings.GeminiModel}"/>
                            </StackPanel>
                        </Border>

                        <!-- Ollama section -->
                        <TextBlock Text="OLLAMA (local AI)" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"
                                   Visibility="{Binding ProviderIsOllama, Converter={StaticResource BoolToVis}}"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                                Visibility="{Binding ProviderIsOllama, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding OllamaStatus}"
                                               VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFCC4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OllamaAvailable}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Green}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="Recheck" Padding="10,4"
                                            Style="{DynamicResource SecondaryButton}"
                                            Command="{Binding CheckOllamaCommand}"/>
                                </Grid>
                                <Label Content="Ollama URL" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.OllamaUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>
                                <Label Content="Model" Padding="0,0,0,4"/>
                                <ComboBox x:Name="ModelComboBox"
                                          ItemsSource="{Binding SuggestedModels, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneTime}"
                                          Margin="0,0,0,8"
                                          SelectionChanged="ModelComboBox_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,4">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontFamily="Segoe UI Semibold" FontSize="12"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           FontFamily="Segoe UI" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <!-- Pull command row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource BgDeep}"
                                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                            CornerRadius="4" Padding="8,6">
                                        <TextBlock Text="{Binding OllamaPullCommand}"
                                                   Foreground="{DynamicResource Accent}"
                                                   FontFamily="Cascadia Code, Consolas" FontSize="12"/>
                                    </Border>
                                    <Button Grid.Column="1" Content="Copy" Margin="6,0,0,0"
                                            Padding="10,6" Style="{DynamicResource SecondaryButton}"
                                            Command="{Binding CopyPullCommandCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Learning section -->
                        <TextBlock Text="LEARNING" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Foreground="{DynamicResource TextSecondary}" Text="Learning data is stored in "/>
                                    <Run Foreground="{DynamicResource Accent}" Text=".betterPrompt/learning.json"/>
                                    <Run Foreground="{DynamicResource TextSecondary}" Text=" inside your codebase. Commit this file so teammates inherit all prior optimizations."/>
                                </TextBlock>
                                <Label Content="Similarity Threshold (0.0 - 1.0)" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.SimilarityThreshold, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,4"/>
                                <TextBlock Text="Higher = stricter matching before using cache. Default: 0.65"
                                           Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Indexer section -->
                        <TextBlock Text="INDEXER" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,24">
                            <StackPanel>
                                <Label Content="Max Files to Index" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.MaxFilesToIndex, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>
                                <Label Content="Max Signature Lines per File" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.MaxSignatureLinesPerFile, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Save Settings" HorizontalAlignment="Left"
                                Command="{Binding SaveSettingsCommand}" Padding="16,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ABOUT TAB -->
            <TabItem Header="About">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24" MaxWidth="500">

                        <!-- App identity -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Better" FontFamily="Segoe UI Semibold" FontSize="28"
                                       Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="Prompt" FontFamily="Segoe UI Semibold" FontSize="28"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <TextBlock Text="Claude Code prompt optimizer"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="Version " FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentVersion}" FontFamily="Segoe UI Semibold"
                                       FontSize="12" Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Description -->
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,20">
                            <TextBlock FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"
                                       LineHeight="20" Foreground="{DynamicResource TextSecondary}"
                                       Text="BetterPrompt analyzes your codebase and rewrites Claude Code prompts to include precise file paths, class names, and method references — reducing token usage and helping Claude find exactly what it needs. All processing runs locally; no data ever leaves your machine."/>
                        </Border>

                        <!-- Update checker -->
                        <TextBlock Text="UPDATES" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,20">
                            <StackPanel>
                                <!-- Status row -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding UpdateStatusMessage}"
                                               FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="Check Now"
                                            Style="{DynamicResource SecondaryButton}"
                                            Command="{Binding CheckForUpdatesCommand}"
                                            Padding="10,4" Margin="10,0,0,0"/>
                                </Grid>

                                <!-- Download button — visible when update available -->
                                <Button Content="{Binding LatestVersion, StringFormat='Download v{0}'}"
                                        Command="{Binding OpenReleasesCommand}"
                                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"
                                        HorizontalAlignment="Left" Padding="14,7"/>
                            </StackPanel>
                        </Border>

                        <!-- Links -->
                        <TextBlock Text="LINKS" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource BgCard}" CornerRadius="4" Padding="14" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="GitHub Repository"
                                        Style="{DynamicResource SecondaryButton}"
                                        Command="{Binding OpenGitHubCommand}"
                                        Padding="12,6" Margin="0,0,8,0"/>
                                <Button Content="View Releases"
                                        Style="{DynamicResource SecondaryButton}"
                                        Command="{Binding OpenReleasesCommand}"
                                        Padding="12,6"/>
                            </StackPanel>
                        </Border>

                        <!-- Credits -->
                        <TextBlock FontFamily="Segoe UI" FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMuted}"
                                   Text="Published by Dan Clark · AGPL v3 License"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontFamily="Segoe UI" FontSize="12"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <!-- Learning count -->
                    <Border Background="{DynamicResource BgCard}" CornerRadius="3" Padding="8,2" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Learning: " Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding LearningEntryCount}" Foreground="{DynamicResource Accent}" FontSize="11" FontFamily="Segoe UI Semibold"/>
                            <TextBlock Text=" entries" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <!-- Active AI provider dot -->
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FFCC4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveProviderAvailable}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource Green}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ActiveProviderLabel}" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <!-- Update available indicator -->
                    <Border Background="{DynamicResource Accent}" CornerRadius="3" Padding="8,2" Margin="0,0,12,0"
                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding OpenReleasesCommand}"/>
                        </Border.InputBindings>
                        <TextBlock Text="{Binding LatestVersion, StringFormat='Update v{0} available'}"
                                   Foreground="{DynamicResource TextOnAccent}" FontSize="11"
                                   FontFamily="Segoe UI Semibold"/>
                    </Border>
                    <!-- Indexing indicator -->
                    <TextBlock Text="Indexing..."
                               Foreground="{DynamicResource Accent}" FontSize="12"
                               Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVis}}"
                               Margin="0,0,16,0"/>
                    <!-- Optimizing indicator -->
                    <TextBlock Text="Optimizing..."
                               Foreground="{DynamicResource Accent}" FontSize="12"
                               Visibility="{Binding IsOptimizing, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
