<Window x:Class="BetterPrompt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BetterPrompt.ViewModels"
        xmlns:conv="clr-namespace:BetterPrompt.Converters"
        mc:Ignorable="d"
        Title="BetterPrompt" Height="780" Width="1100"
        Icon="Assets/app.ico"
        Background="{StaticResource BgDeep}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Better" FontFamily="Segoe UI Semibold" FontSize="20"
                               Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="Prompt" FontFamily="Segoe UI Semibold" FontSize="20"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="  /  Claude Code prompt optimizer"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <TabControl Grid.Row="1" Background="{StaticResource BgDeep}">

            <!-- OPTIMIZER TAB -->
            <TabItem Header="Prompt Optimizer">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Codebase panel -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="CODEBASE"
                                   FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,10"/>

                        <!-- Path row -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding CodebasePath, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="..." Margin="6,0,0,0" Padding="10,6"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BrowseCodebaseCommand}"/>
                        </Grid>

                        <Button Grid.Row="2" Content="Index Codebase"
                                Command="{Binding IndexCodebaseCommand}"
                                IsEnabled="{Binding IsIndexing, Converter={StaticResource InvBoolToVis}}"
                                Margin="0,0,0,12" HorizontalAlignment="Stretch"/>

                        <!-- File tree -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="FILES" FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding FileTree}"
                                     Visibility="{Binding HasCodebase, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Grid.Row="1" Text="No codebase loaded"
                                       Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding HasCodebase, Converter={StaticResource InvBoolToVis}}"/>
                        </Grid>
                    </Grid>

                    <!-- Right: Prompt panel -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Raw prompt -->
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="YOUR PROMPT"
                                       FontFamily="Segoe UI Semibold" FontSize="10"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <Grid Grid.Row="1">
                                <TextBox Text="{Binding RawPrompt, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Segoe UI" FontSize="13"
                                         IsEnabled="{Binding HasCodebase}"/>
                                <!-- Overlay shown when no codebase is loaded -->
                                <Border Background="#CC0D0D0D" CornerRadius="4"
                                        Visibility="{Binding HasCodebase, Converter={StaticResource InvBoolToVis}}"
                                        IsHitTestVisible="False">
                                    <TextBlock Text="Index a codebase to enable prompt optimization"
                                               Foreground="{StaticResource TextMuted}"
                                               FontFamily="Segoe UI" FontSize="13" FontStyle="Italic"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Optimize button row -->
                        <Grid Grid.Row="1" Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Height="1" Background="{StaticResource Border}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Optimize Prompt"
                                    Padding="20,10" FontSize="14"
                                    Command="{Binding OptimizePromptCommand}"
                                    IsEnabled="{Binding CanOptimize}"/>
                            <Border Grid.Column="2" Height="1" Background="{StaticResource Border}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Stats strip -->
                        <Border Grid.Row="2" Margin="0,0,0,10"
                                Visibility="{Binding HasOptimizedPrompt, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Rules applied -->
                                <Border Grid.Column="0" Background="{StaticResource BgCard}"
                                        CornerRadius="4" Padding="10,8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="RULES APPLIED" FontFamily="Segoe UI Semibold" FontSize="9"
                                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding StatRulesApplied}" FontFamily="Segoe UI Semibold"
                                                   FontSize="22" Foreground="{StaticResource Accent}"/>
                                    </StackPanel>
                                </Border>

                                <!-- LLM used -->
                                <Border Grid.Column="1" CornerRadius="4" Padding="10,8" Margin="0,0,6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource BgCard}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatOllamaUsed}" Value="True">
                                                    <Setter Property="Background" Value="#FF1A2A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="OLLAMA PASS" FontFamily="Segoe UI Semibold" FontSize="9"
                                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock FontFamily="Segoe UI Semibold" FontSize="22">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="No"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatOllamaUsed}" Value="True">
                                                            <Setter Property="Text" Value="Yes"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Cache hit -->
                                <Border Grid.Column="2" CornerRadius="4" Padding="10,8" Margin="0,0,6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource BgCard}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatCacheHit}" Value="True">
                                                    <Setter Property="Background" Value="#FF1A2A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="CACHE HIT" FontFamily="Segoe UI Semibold" FontSize="9"
                                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock FontFamily="Segoe UI Semibold" FontSize="22">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="No"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatCacheHit}" Value="True">
                                                            <Setter Property="Text" Value="Yes"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10"
                                                   Visibility="{Binding StatCacheHit, Converter={StaticResource BoolToVis}}">
                                            <TextBlock.Text>
                                                <Binding Path="StatCacheScore" StringFormat="{}{0:P0} match"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Chars delta -->
                                <Border Grid.Column="3" Background="{StaticResource BgCard}"
                                        CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="CHARS DELTA" FontFamily="Segoe UI Semibold" FontSize="9"
                                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding StatOriginalLength}" FontFamily="Segoe UI Semibold"
                                                       FontSize="14" Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Bottom"/>
                                            <TextBlock Text=" → " FontFamily="Segoe UI" FontSize="12"
                                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom"/>
                                            <TextBlock Text="{Binding StatOptimizedLength}" FontFamily="Segoe UI Semibold"
                                                       FontSize="14" Foreground="{StaticResource Accent}"
                                                       VerticalAlignment="Bottom"/>
                                        </StackPanel>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10">
                                            <TextBlock.Text>
                                                <Binding Path="StatCharsRemoved" StringFormat="{}{0} chars trimmed"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Optimized prompt -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Header row with source badge -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="OPTIMIZED PROMPT"
                                           FontFamily="Segoe UI Semibold" FontSize="10"
                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                <!-- Source badge -->
                                <Border Grid.Column="1" Margin="8,0,0,0" Padding="6,2"
                                        CornerRadius="3"
                                        Visibility="{Binding HasOptimizedPrompt, Converter={StaticResource BoolToVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource BgCard}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FromCache}" Value="True">
                                                    <Setter Property="Background" Value="#FF1A3A2A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SourceLabel}"
                                               FontFamily="Segoe UI" FontSize="10" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FromCache}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <TextBox Grid.Row="1"
                                     Text="{Binding OptimizedPrompt, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Segoe UI" FontSize="13"
                                     IsReadOnly="False"/>
                        </Grid>

                        <!-- Changes + copy -->
                        <Grid Grid.Row="4" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Explanation + changes -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0"
                                        Visibility="{Binding HasOptimizedPrompt, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Explanation}"
                                           Foreground="{StaticResource Green}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding Changes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat='- {0}'}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontFamily="Segoe UI" FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <Button Content="Copy Prompt"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CopyToClipboardCommand}"
                                        IsEnabled="{Binding HasOptimizedPrompt}"
                                        Padding="14,8"/>
                                <Button Content="Copy Rules"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CopyRulesCommand}"
                                        IsEnabled="{Binding HasOptimizedPrompt}"
                                        Padding="14,8" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- SETTINGS TAB -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24" MaxWidth="540">
                        <TextBlock Text="SETTINGS" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,20"/>

                        <!-- Ollama section -->
                        <TextBlock Text="OLLAMA (local AI)" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{StaticResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding OllamaStatus}"
                                               VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFCC4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OllamaAvailable}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="Recheck" Padding="10,4"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CheckOllamaCommand}"/>
                                </Grid>
                                <Label Content="Ollama URL" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.OllamaUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>
                                <Label Content="Model" Padding="0,0,0,4"/>
                                <ComboBox x:Name="ModelComboBox"
                                          ItemsSource="{Binding SuggestedModels, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneTime}"
                                          Margin="0,0,0,8"
                                          SelectionChanged="ModelComboBox_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,4">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontFamily="Segoe UI Semibold" FontSize="12"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontFamily="Segoe UI" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <!-- Pull command row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BgDeep}"
                                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                                            CornerRadius="4" Padding="8,6">
                                        <TextBlock Text="{Binding OllamaPullCommand}"
                                                   Foreground="{StaticResource Accent}"
                                                   FontFamily="Cascadia Code, Consolas" FontSize="12"/>
                                    </Border>
                                    <Button Grid.Column="1" Content="Copy" Margin="6,0,0,0"
                                            Padding="10,6" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CopyPullCommandCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Learning section -->
                        <TextBlock Text="LEARNING" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{StaticResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Foreground="{StaticResource TextSecondary}" Text="Learning data is stored in "/>
                                    <Run Foreground="{StaticResource Accent}" Text=".betterPrompt/learning.json"/>
                                    <Run Foreground="{StaticResource TextSecondary}" Text=" inside your codebase. Commit this file so teammates inherit all prior optimizations."/>
                                </TextBlock>
                                <Label Content="Similarity Threshold (0.0 - 1.0)" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.SimilarityThreshold, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,4"/>
                                <TextBlock Text="Higher = stricter matching before using cache. Default: 0.65"
                                           Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Indexer section -->
                        <TextBlock Text="INDEXER" FontFamily="Segoe UI Semibold" FontSize="10"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{StaticResource BgCard}" CornerRadius="4" Padding="12" Margin="0,0,0,24">
                            <StackPanel>
                                <Label Content="Max Files to Index" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.MaxFilesToIndex, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>
                                <Label Content="Max Signature Lines per File" Padding="0,0,0,4"/>
                                <TextBox Text="{Binding Settings.MaxSignatureLinesPerFile, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Save Settings" HorizontalAlignment="Left"
                                Command="{Binding SaveSettingsCommand}" Padding="16,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondary}"
                           FontFamily="Segoe UI" FontSize="12"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <!-- Learning count -->
                    <Border Background="{StaticResource BgCard}" CornerRadius="3" Padding="8,2" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Learning: " Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding LearningEntryCount}" Foreground="{StaticResource Accent}" FontSize="11" FontFamily="Segoe UI Semibold"/>
                            <TextBlock Text=" entries" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <!-- Ollama dot -->
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FFCC4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OllamaAvailable}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Green}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Ollama" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <!-- Indexing indicator -->
                    <TextBlock Text="Indexing..."
                               Foreground="{StaticResource Accent}" FontSize="12"
                               Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVis}}"
                               Margin="0,0,16,0"/>
                    <!-- Optimizing indicator -->
                    <TextBlock Text="Optimizing..."
                               Foreground="{StaticResource Accent}" FontSize="12"
                               Visibility="{Binding IsOptimizing, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
